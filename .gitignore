[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/

# 유니티 메타데이터 충돌 방지
[Mm]emory[Cc]aptures/
[Aa]ssets/AssetStoreTools*

# IDE / 에디터 설정 파일 (VS, VSCode, Rider 등)
.vs/
.idea/
.vscode/
ExportedObj/
